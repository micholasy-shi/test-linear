{
  "name": "@vincentkoc/qrcode-tui",
  "version": "0.2.1",
  "description": "Modern QR rendering helpers for Node.js CLIs and setup flows",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": "Vincent Koc",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vincentkoc/qrcode-tui.git"
  },
  "homepage": "https://github.com/vincentkoc/qrcode-tui#readme",
  "bugs": {
    "url": "https://github.com/vincentkoc/qrcode-tui/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "qrcode-tui": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/vincentkoc"
  },
  "directories": {
    "test": "test"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node --test test/*.test.mjs",
    "verify": "pnpm check && pnpm test",
    "prepublishOnly": "pnpm verify"
  },
  "keywords": [
    "ascii",
    "cli",
    "png",
    "qr",
    "qrcode",
    "svg",
    "terminal",
    "tui",
    "utf8"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.9.2"
  }
}
